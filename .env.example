APP_ENV=development
AGENT_PORT=8080
POS_API_URL=http://localhost:8081
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/replace/me
CLIPS_DIR=./data/clips
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
API_TOKEN=
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DETECT_PER_WINDOW=45
RATE_LIMIT_CHAT_PER_WINDOW=20
MAX_IMAGE_BASE64_CHARS=4000000
COPILOT_PROVIDER=local
COPILOT_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_API_URL=http://127.0.0.1:11434
DETECTOR_MODEL_PATH=yolov8s.pt
DETECTOR_PRETRAINED_MODEL=yolov8m.pt
DETECTOR_DEVICE=cuda:0
